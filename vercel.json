{
  "headers": [
    {
      "source": "/store.js",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript"
        }
      ]
    },
    {
      "source": "/store.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/store.html"
    }
  ],
  "cleanUrls": true
}
